# ============================================================
# SERVICE-ONE — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Google Cloud / Vertex AI ─────────────────────────────────
# Your GCP project ID — needed for Vertex AI + ADK agents
GCP_PROJECT_ID=GCP_PROJECT_ID
# GCP region for Vertex AI (e.g. us-central1, asia-south1)
GCP_REGION=region
# Path to service account JSON key (local dev only)
# In Cloud Run, use Workload Identity instead
GOOGLE_APPLICATION_CREDENTIALS=CLIENT_ID

# ── Vertex AI Agent Models ───────────────────────────────────
# Agents 1-4: Locality, Provider, Community, Trust
AGENT_MODEL_FLASH_LITE=gemini-2.5-flash-lite
# Agent 5: Final Advisor
AGENT_MODEL_FLASH=gemini-2.5-flash

# ── Google Maps API (backend) ─────────────────────────────────
# Used by ProviderComparisonAgent for Places API + Geocoding
# Same key as frontend or a server-side restricted key
GOOGLE_MAPS_API_KEY=GOOGLE_MAPS_API_KEY

# ── Web Scraper Config ────────────────────────────────────────
# Sources used by LocalityPriceAgent to ground pricing data
# Comma-separated list of allowed scraper target domains
SCRAPER_ALLOWED_DOMAINS=justdial.com,sulekha.com,urbancompany.com
# Max concurrent scraper requests
SCRAPER_MAX_CONCURRENCY=3
# Request timeout in seconds
SCRAPER_TIMEOUT_SECONDS=20
# User-Agent header for scraper requests
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; ServiceOneBot/1.0)

# ── Redis Cache ───────────────────────────────────────────────
# Used for caching quote-check results (same city+appliance+service)
REDIS_URL=REDIS_URL
# Cache TTL for quote results in seconds (default: 2 hours)
CACHE_TTL_SECONDS=7200

# ── Google OAuth (backend) ────────────────────────────────────
GOOGLE_CLIENT_ID=CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET
# Redirect URI registered in Google Console
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Cloud Storage (GCS) ───────────────────────────────────────
# Bucket for user-uploaded bill images and quote proof photos
GCS_BUCKET_NAME=Bucket
GCS_SIGNED_URL_EXPIRY_MINUTES=15

# ── App Security ──────────────────────────────────────────────
# Secret for signing JWT sessions — generate with: openssl rand -hex 32
JWT_SECRET_KEY=JWT KEY
JWT_ALGORITHM=key
JWT_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────────
# Frontend URL (local dev or production Cloud Run URL)
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_QUOTE_CHECKS_PER_MINUTE=10
RATE_LIMIT_REPORT_SUBMISSIONS_PER_HOUR=5

# ── App Config ────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO


VERTEX_AI_PROJECT_ID=GCP_PROJECT_ID
VERTEX_AI_LOCATION=us-central1